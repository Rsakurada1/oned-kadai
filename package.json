{
  "name": "oned-kadai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "cross-env VISUAL_SNAPSHOT=1 playwright test src/e2e/visual-snapshot.spec.ts",
